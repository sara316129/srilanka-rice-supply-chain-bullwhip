  <previewCommands>setup repeat 75 [ go ]</previewCommands>
  <experiments>
    <experiment name="government-comparison" repetitions="50" sequentialRunOrder="true" runMetricsEveryStep="false" timeLimit="156">
      <setup>setup</setup>
      <go>go</go>
      <metrics>
        <metric>bullwhip-ratio-farmer</metric>
        <metric>bullwhip-ratio-retailer</metric>
        <metric>[food-security-index] of one-of governments</metric>
        <metric>[production-capacity] of one-of farmers</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="government-intervention?">
          <value value="true"></value>
          <value value="false"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
  </experiments>
</model>
